{
  "name": "@contextlab/app-context",
  "version": "0.1.4",
  "description": "Keep your AI coding assistant up to speed. App-context generates structured, sanitized Markdown context from your app's runtime activity, so Windsurf, Cursor, and other AI coding assistants can quickly understand what your app is actually doing without you reconstructing history or copy-pasting logs.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ttjordan/app-context.git",
    "directory": "packages/app-context"
  },
  "keywords": [
    "ai",
    "coding-assistant",
    "windsurf",
    "cursor",
    "context",
    "debugging",
    "express",
    "middleware",
    "agent",
    "markdown"
  ],
  "type": "module",
  "main": "./index.cjs",
  "module": "./index.js",
  "exports": {
    ".": {
      "import": "./index.js",
      "require": "./index.cjs"
    }
  },
  "bin": {
    "app-context": "bin/app-context.js"
  },
  "files": [
    "bin",
    "src",
    "index.js",
    "index.cjs"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {},
  "scripts": {
    "summarize": "node ./bin/app-context.js summarize --output ../demo-app/agent-state --tail 2000",
    "test": "node -e \"console.log('no tests yet')\""
  }
}
